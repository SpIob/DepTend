# =============================================================================
# deptend.dev — Environment Variables
# Copy this file to .env.local (never commit .env.local)
# =============================================================================

# --- Database (Neon PostgreSQL) ---
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# --- GitHub OAuth ---
# Create at: https://github.com/settings/developers → OAuth Apps
GH_CLIENT_ID=""
GH_CLIENT_SECRET=""

# --- GitHub API Token ---
# Personal access token (classic) — read:public_repo scope only
# Required for GHSA queries and to avoid 60 req/hr rate limit
GITHUB_TOKEN=""

# --- On-demand ingestion (repo submission) ---
# Fine-grained PAT scoped to this repo only, actions: write — triggers
# workflow_dispatch from the API route on repo submission. Distinct from
# GITHUB_TOKEN above, which is auto-injected inside Actions runs only and
# can't be used from an external process (see ADR 0013).
GH_DISPATCH_TOKEN=""
# "owner/name" for deptend.dev's own repo (not the submitted target repo)
GH_REPO=""

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Set to your Vercel URL in production; http://localhost:3000 in dev
NEXTAUTH_URL="http://localhost:3000"

# --- App ---
# Hard cap on indexed repos (MVP = 3). Application layer enforces this.
NEXT_PUBLIC_MAX_REPOS="10"
